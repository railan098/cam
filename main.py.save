#     salvar_deteccao(frame) # Passamos o frame atual para a funçã
#     detectado = True
def salvar_no_banco(frame):
    try:
        # Use o caminho completo do seu Linux
        diretorio = "/home/railanalves/Documentos/test-script/cam/capturas/"
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        nome_foto = f"{diretorio}invasao_{timestamp}.jpg"
        
        # Tenta salvar e verifica o retorno
        sucesso_foto = cv2.imwrite(nome_foto, frame)
        
        if sucesso_foto:
            print(f">>> FOTO SALVA COM SUCESSO EM: {nome_foto}")
        else:
